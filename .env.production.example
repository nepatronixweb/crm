# Production — CRM on port 3001 (crm.nepatronix.org)
# Same VPS as ETG (port 3000) but SEPARATE folder and SEPARATE MongoDB database.
#
# ── Server layout (example) ───────────────────────────────────────────────────
#   /var/www/etg   →  ETG app      →  PM2 "etg"  →  port 3000
#   /var/www/crm   →  this CRM app →  PM2 "crm"  →  port 3001
#   MongoDB on 127.0.0.1:27017:
#     database "etg"  for ETG  (do NOT share with CRM)
#     database "crm"  for CRM  (use URI below)
#
# ── First-time VPS setup ──────────────────────────────────────────────────────
#   cd /var/www/crm
#   cp .env.production.example .env.production
#   # Create MongoDB user + database "crm":
#   sudo CRM_DB_USER=crmuser CRM_DB_PASS='YourStrongPass!' bash scripts/setup-vps-mongodb-crm.sh
#   # Edit .env.production — paste MONGODB_URI from script output
#   npx tsx --env-file=.env.production scripts/reset-admin-password.ts
#   npm ci && npm run build
#   pm2 start ecosystem.config.cjs && pm2 save
#   sudo cp deploy/nginx-crm.nepatronix.org.conf /etc/nginx/sites-available/crm.nepatronix.org
#   sudo ln -sf /etc/nginx/sites-available/crm.nepatronix.org /etc/nginx/sites-enabled/
#   sudo certbot --nginx -d crm.nepatronix.org

# ── MongoDB on same VPS as ETG (recommended — separate DB name "crm") ─────────
MONGODB_URI=mongodb://crmuser:YOUR_PASSWORD@127.0.0.1:27017/crm?authSource=admin

# ── MongoDB Atlas (alternative) ───────────────────────────────────────────────
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/crm?retryWrites=true&w=majority

# ── NextAuth (must match public URL exactly) ───────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://crm.nepatronix.org

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Vercel Blob (file uploads) ────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Cron Security ─────────────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret-here

# ── SMTP / Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# ── HR (optional) ─────────────────────────────────────────────────────────────
OFFICE_IP=
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_METERS=500
HR_TIMEZONE=Asia/Kathmandu
