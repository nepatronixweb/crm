# Production — crm.nepatronix.org (port 3001 behind nginx)
# Copy on the server:  cp .env.production.example .env.production
# Then fill secrets and run:  npm run build && pm2 start ecosystem.config.cjs

# ── MongoDB (Atlas recommended for production) ────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/etg-crm?retryWrites=true&w=majority

# ── NextAuth (must match public URL exactly) ───────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://crm.nepatronix.org

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Vercel Blob (file uploads) ────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Cron Security ─────────────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret-here

# ── SMTP / Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# ── HR (optional) ─────────────────────────────────────────────────────────────
OFFICE_IP=
OFFICE_LAT=
OFFICE_LNG=
OFFICE_RADIUS_METERS=500
HR_TIMEZONE=Asia/Kathmandu
